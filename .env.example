# ============================================================
# Variables d'environnement — Portfolio Ndawa Mohammed
# ============================================================
# Copier ce fichier en `.env` et remplir les valeurs.
# Le fichier `.env` n'est JAMAIS commité (voir .gitignore).
# ============================================================

# --- Django ---
# Génère une nouvelle clé : python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=change-me-pour-une-vraie-cle-aleatoire

# True en local, False en production
DEBUG=True

# Hôtes autorisés, séparés par des virgules
# Ex en prod : ndawa-mohammed.onrender.com,ndawamohammed.com,www.ndawamohammed.com
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Base de données ---
# Vide ou absent → utilise SQLite local (db.sqlite3) — pratique en dev
# En production : DATABASE_URL=postgres://user:password@host:port/dbname
# (Render fournit cette URL automatiquement quand on crée une base Postgres)
DATABASE_URL=

# --- Email (formulaire de contact) ---
# En dev, laisser EMAIL_BACKEND=console pour voir les emails dans le terminal.
# En prod, mettre EMAIL_BACKEND=smtp.
EMAIL_BACKEND=console

# Config SMTP (utilisée seulement si EMAIL_BACKEND=smtp)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=ecladorvynil507@gmail.com
# /!\ Mot de passe d'application Gmail (PAS le mot de passe du compte).
# https://myaccount.google.com/apppasswords
EMAIL_HOST_PASSWORD=

# Adresse destinataire qui recevra les messages du formulaire
CONTACT_RECIPIENT_EMAIL=ecladorvynil507@gmail.com

# Expéditeur affiché dans les emails envoyés par le site
DEFAULT_FROM_EMAIL=Portfolio Ndawa <ecladorvynil507@gmail.com>
